module slh_dsa_tests @private;

import std::crypto;

bool csprng_supported = false;
fn void _runtime_check_csprng() @init
{
	char[64] tmp;
	if (try entropy::fill(tmp[..]))
	{
		csprng_supported = true;
	}
}

struct SlhDsaTestVector <N>
{
	SlhDsaKeyPair{N} key_pair;
	char[] message;
	char[] context;
	char[] signature;
	bool hedged;
	SlhDsaNode{N >> 3} addrnd;
}


module slh_dsa_tests @test;

import std::crypto @public;
import std::bits;

fn void to_int()
{
	char[8] tmp @align(ulong.sizeof);
	for (usz i = 0; i < 256; i++)
	{
		if (csprng_supported) entropy::fill(tmp[..])!!;
		if (!csprng_supported) tmp[7] = (char)i;
		ulong num = env::BIG_ENDIAN ??? *(ulong*)tmp : bswap(*(ulong*)&tmp);
		test::eq(num, slh_dsa::to_int(tmp, ulong.sizeof));
	}
}

fn void to_byte()
{
	test::eq(x'0a', slh_dsa::to_byte(10, 1));
	test::eq(x'0000f000', slh_dsa::to_byte(61440, 4));
	test::eq(x'0000065dc57bc29dec77', slh_dsa::to_byte(458739872398437495, 10));
}

fn void base_2b()
{
	char[] input = x'048c048c048c048c048c048c';
	uint128[16] split = slh_dsa::base_2b(input, 4, 16);
	for (usz bits = 0; bits < 32; bits += 4)
	{
		test::eq(split[bits >> 2], (input[bits >> 3] & (0x0F << ((bits+4) % 8))) >> ((bits+4) % 8));
	}

	uint128[5] s = slh_dsa::base_2b(x'7777', 3, 5);   // 0b0111_0111_0111_0111, split bits into 5 groups of 3
	test::eq(s[0], 0b011);
	test::eq(s[1], 0b101);
	test::eq(s[2], 0b110);
	test::eq(s[3], 0b111);
	test::eq(s[4], 0b011);
}

fn void simple_keygens()
{
	if (!csprng_supported) return;

	SlhDsaKeyPair{128} a = slh_dsa::keygen{128}()!!;
	test::ne(a, (SlhDsaKeyPair{128}){});

	SlhDsaKeyPair{192} b = slh_dsa::keygen{192}()!!;
	test::ne(b, (SlhDsaKeyPair{192}){});

	SlhDsaKeyPair{256} c = slh_dsa::keygen{256}()!!;
	test::ne(c, (SlhDsaKeyPair{256}){});
}

fn void simple_sign_128()
{
	foreach (i, v : VECTORS_128)
	{
		char[] sig = slh_dsa::sign{128}(tmem, v.key_pair.privkey, v.message, context: v.context, hedged: v.hedged, additional_randomness: v.addrnd)!!;
		test::eq(sig.len, v.signature.len);
		// Do not use test::eq here unless you want 25+KiB dumping to stdout on failure.
		test::@check(v.signature == sig, "Signature mismatch for vector %d.\n\tEXP: %h...\n\tGOT: %h...\n", i, v.signature[:48], sig[:48]);
	}
}

// macro char[]? sign(Allocator allocator, SlhDsaPrivateKey{N} privkey, char[] message, char[] context = {},
// 	bool hedged = true, SlhDsaHashType $type = SHAKE, SlhDsaMode $mode = FAST) <N> => @pool()

// ========================================================

const SlhDsaTestVector{128}[] VECTORS_128 = {
	{
		.key_pair = {
			.pubkey = {
				.root = x'db3f5ee63a2341fbb1077deacd4869e7',
				.seed = x'b4e8cf35fb099d0773ab32fac6ad4d42',
			},
			.privkey = {
				.seed = x'3ea2b5817ce7f94595be7adb65ab4ab3',
				.prf  = x'6ab130011114dd7ba651a087b073780b',
				.pub = {
					.root = x'db3f5ee63a2341fbb1077deacd4869e7',
					.seed = x'b4e8cf35fb099d0773ab32fac6ad4d42',
				}
			}
		},
		.message = x'',
		.context = x'',
		.hedged = true,
		.addrnd = x'5d87efb173a3d679660b928e709d0b26',
		.signature = x'',
	}
};
